{
  "name": "rtps",
  "version": "1.0.0",
  "description": "Real-Time Refund Status Updates – SMS & Email Notification System",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc --noEmit && tsc -p tsconfig.build.json",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@sendgrid/eventwebhook": "^8.0.0",
    "@sendgrid/mail": "^8.1.4",
    "@trpc/server": "^11.0.0",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "dotenv": "^16.4.5",
    "drizzle-kit": "^0.31.0",
    "drizzle-orm": "^0.41.0",
    "node-cron": "^3.0.3",
    "postgres": "^3.4.4",
    "tsx": "^4.19.0",
    "twilio": "^5.3.3",
    "typescript": "^5.5.4",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^2.0.5",
    "supertest": "^7.0.0",
    "vitest": "^2.0.5"
  }
}
