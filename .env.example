# Database
DATABASE_URL=postgresql://user:password@localhost:5432/rtps

# Auth
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# IRS FIRE API
IRS_FIRE_CERT_PATH=/certs/irs-fire-cert.pem
IRS_FIRE_PRIVATE_KEY_PATH=/certs/irs-fire-key.pem
IRS_FIRE_ENDPOINT=https://fire.irs.gov/firetss/

# Twilio (SMS)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+15551234567

# SendGrid (Email)
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=notifications@yourtaxfirm.com
SENDGRID_FROM_NAME=Your Tax Firm

# Admin Security
ADMIN_MFA_REQUIRED=true
ADMIN_IP_ALLOWLIST=["203.0.113.0"]
ADMIN_SESSION_TIMEOUT=1800
AUDIT_LOG_RETENTION_DAYS=2555

# Tax Year Config
TAX_YEAR_CURRENT=2024
TAX_YEAR_PRIOR=2023
FILING_DEADLINE_FEDERAL=2025-04-15

# Encryption
ENCRYPTION_KEY=your-32-char-encryption-key-here

# Credential Rotation
CREDENTIAL_ROTATION_DAYS=90

# Account Tier
ACCOUNT_TIER=enterprise

# Worker Config
REFUND_POLL_INTERVAL_MINUTES=60
NOTIFICATION_WORKER_ENABLED=true

# Bureau of Fiscal Services (BFS) – Treasury Offset Program & Disbursement
# API documentation: https://www.fiscal.treasury.gov/developer-resources/
BFS_API_BASE_URL=https://api.fiscal.treasury.gov/services/api/
BFS_API_KEY=your-bfs-api-key-here
# Client ID registered with Treasury for OAuth-style service authentication
BFS_CLIENT_ID=your-bfs-client-id-here
# Shared secret for HMAC request signing
BFS_CLIENT_SECRET=your-bfs-client-secret-here
# Timeout in milliseconds for BFS API requests
BFS_REQUEST_TIMEOUT_MS=20000
# Maximum retry attempts on transient BFS errors
BFS_MAX_RETRIES=3

# PDF Report Generation
# Portal base URL embedded in PDF reports (e.g., QR code / link)
PORTAL_BASE_URL=https://app.yourdomain.com
# Firm branding shown in PDF header
FIRM_NAME=Your Tax Firm
FIRM_ADDRESS_LINE1=123 Main St
FIRM_CITY_STATE_ZIP=Anytown, ST 00000
FIRM_PHONE=(800) 555-0100
FIRM_WEBSITE=https://www.yourtaxfirm.com
# =============================================================================
# Real-Time Refund Status Updates (RTPS) – Environment Variables
# =============================================================================
# Copy this file to .env and fill in all values before running the application.
# NEVER commit .env to version control.

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://user:password@localhost:5432/rtps_db"

# -----------------------------------------------------------------------------
# Encryption (AES-256-GCM)
# Must be a 64-character hex string (32 bytes).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# -----------------------------------------------------------------------------
ENCRYPTION_KEY="replace_with_64_char_hex_string_here_32_bytes_total_padding_xyz"

# -----------------------------------------------------------------------------
# Twilio – SMS provider
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your_twilio_auth_token"
TWILIO_FROM_NUMBER="+15005550006"
# Optional: Twilio Messaging Service SID (overrides FROM_NUMBER when set)
TWILIO_MESSAGING_SERVICE_SID=""
# Webhook signing secret for validating Twilio status callbacks
TWILIO_WEBHOOK_SECRET="your_twilio_webhook_secret"

# -----------------------------------------------------------------------------
# SendGrid – Email provider
# -----------------------------------------------------------------------------
SENDGRID_API_KEY="SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
SENDGRID_FROM_EMAIL="noreply@yourdomain.com"
SENDGRID_FROM_NAME="Tax Refund Updates"
# Webhook verification key from SendGrid Event Webhook settings
SENDGRID_WEBHOOK_VERIFICATION_KEY="your_sendgrid_webhook_verification_key"

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV="development"
PORT="3000"
APP_URL="https://app.yourdomain.com"
LOG_LEVEL="info"

# -----------------------------------------------------------------------------
# TCPA / Compliance
# -----------------------------------------------------------------------------
# Comma-separated list of US area codes considered NANP landline-only (optional override)
BLOCKED_AREA_CODES=""
# Quiet hours (24h, Eastern Time) – messages suppressed outside these hours
QUIET_HOURS_START="8"
QUIET_HOURS_END="21"
COMPLIANCE_TIMEZONE="America/New_York"

# -----------------------------------------------------------------------------
# Queue / Scheduler
# -----------------------------------------------------------------------------
# Cron expression for the daily digest job (default: 8 AM daily)
DIGEST_CRON_SCHEDULE="0 8 * * *"
# Cron expression for the weekly digest job (default: Monday 8 AM)
WEEKLY_DIGEST_CRON_SCHEDULE="0 8 * * 1"
# Max retry attempts for failed notifications
MAX_NOTIFICATION_RETRIES="3"
# Retry backoff base in milliseconds
RETRY_BACKOFF_BASE_MS="60000"

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
# Max SMS messages per client per 24-hour window
SMS_RATE_LIMIT_PER_DAY="10"
# Max email messages per client per 24-hour window
EMAIL_RATE_LIMIT_PER_DAY="20"
